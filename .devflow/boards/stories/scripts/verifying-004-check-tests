#!/usr/bin/env bash
set -euo pipefail
# Exit verifying: re-run automated Test Scenarios from card.md.

board="${1:?board name required}"
card_id="${2:?card id required}"
: "$board" "$card_id"

card_dir="${DEVFLOW_CARD_DIR:?DEVFLOW_CARD_DIR not set}"
card_md="${card_dir}/card.md"
repo_root="${DEVFLOW_REPO_ROOT:?DEVFLOW_REPO_ROOT not set}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=building-lib.sh
source "${script_dir}/building-lib.sh"

fail() {
  echo "verifying-004: $*" >&2
  exit 1
}

if [ ! -f "$card_md" ]; then
  fail "missing card.md"
fi

cd "$repo_root"

if ! building_run_scenario_tests "$card_md"; then
  cmd="${BUILDING_SCENARIO_FAILURE_CMD:-<unknown>}"
  fail "automated scenario failed: ${cmd}"
fi

exit 0
