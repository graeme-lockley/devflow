#!/usr/bin/env bash
set -euo pipefail
# Exit finishing: run finish-story skill via pi.

board="${1:?board name required}"
card_id="${2:?card id required}"
: "$board" "$card_id"

if [ "${DEVFLOW_SKIP_PI:-}" = "1" ]; then
  echo "finishing-002: DEVFLOW_SKIP_PI=1: skipping pi finish-story" >&2
  exit 0
fi

if ! command -v pi >/dev/null 2>&1; then
  echo "finishing-002: pi not on PATH" >&2
  exit 1
fi

if [ -z "${DEVFLOW_MEDIUM_MODEL:-}" ]; then
  echo "finishing-002: DEVFLOW_MEDIUM_MODEL is not set" >&2
  exit 1
fi

board_dir="${DEVFLOW_BOARD_DIR:?DEVFLOW_BOARD_DIR not set}"
skill_dir="${board_dir}/skills/finish-story"
renderer="${board_dir}/scripts/lib/pi-render.sh"
# shellcheck source=lib/pi-prompt.sh
source "${board_dir}/scripts/lib/pi-prompt.sh"
prompt="$(pi_prompt_phase finish-story finish)"

set -o pipefail
pi --skill "$skill_dir" --model "${DEVFLOW_MEDIUM_MODEL}" --print --mode json \
  "$prompt" \
  | "$renderer"
exit ${PIPESTATUS[0]}
