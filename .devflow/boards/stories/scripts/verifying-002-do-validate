#!/usr/bin/env bash
set -euo pipefail
# Exit verifying: run validate-story skill via pi.

board="${1:?board name required}"
card_id="${2:?card id required}"
: "$board" "$card_id"

if [ "${DEVFLOW_SKIP_PI:-}" = "1" ]; then
  echo "verifying-002: DEVFLOW_SKIP_PI=1: skipping pi validate-story" >&2
  exit 0
fi

if ! command -v pi >/dev/null 2>&1; then
  echo "verifying-002: pi not on PATH" >&2
  exit 1
fi

if [ -z "${DEVFLOW_HEAVY_MODEL:-}" ]; then
  echo "verifying-002: DEVFLOW_HEAVY_MODEL is not set" >&2
  exit 1
fi

skill_dir="${DEVFLOW_BOARD_DIR:?DEVFLOW_BOARD_DIR not set}/skills/validate-story"
exec pi --skill "$skill_dir" --model "${DEVFLOW_HEAVY_MODEL}" --print \
  "Using the skill validate-story, please verify the story ${card_id}."
