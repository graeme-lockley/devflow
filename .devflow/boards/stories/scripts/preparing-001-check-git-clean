#!/usr/bin/env bash
set -euo pipefail
# Exit preparing: working tree must be clean before prepare-story runs.

board="${1:?board name required}"
card_id="${2:?card id required}"
: "$board" "$card_id"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "preparing-001: not inside a git work tree" >&2
  exit 1
fi

dirty=$(git status --porcelain)
if [ -n "$dirty" ]; then
  echo "preparing-001: git working tree must be clean (no modified, staged, or untracked files)" >&2
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    echo "$line" >&2
  done <<< "$dirty"
  exit 1
fi

exit 0
