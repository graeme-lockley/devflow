#!/usr/bin/env bash
set -euo pipefail
# Exit building (entry): clean tree, or only story-scoped WIP (retry after failed advance).

board="${1:?board name required}"
card_id="${2:?card id required}"
: "$board" "$card_id"

repo_root="${DEVFLOW_REPO_ROOT:?DEVFLOW_REPO_ROOT not set}"
card_dir="${DEVFLOW_CARD_DIR:?DEVFLOW_CARD_DIR not set}"
card_md="${card_dir}/card.md"
repo_root="${repo_root%/}"
card_dir="${card_dir%/}"
card_rel="${card_dir#"$repo_root"/}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=building-lib.sh
source "${script_dir}/building-lib.sh"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "building-001: not inside a git work tree" >&2
  exit 1
fi

porcelain=$(git -C "$repo_root" status --porcelain)
if [ -z "$porcelain" ]; then
  exit 0
fi

building_collect_allowed_doc_paths "$card_md"

_check_path() {
  local path="$1"
  if building_path_allowed_for_story "$path" "$card_rel"; then
    return 0
  fi
  case "$path" in
    .devflow/boards/*/scripts/*|.devflow/boards/*/skills/*)
      echo "building-001: board script/skill changes must be committed before advance: ${path}" >&2
      ;;
    *)
      echo "building-001: change outside story scope: ${path}" >&2
      ;;
  esac
  echo "building-001: commit or stash unrelated files; a clean tree is required at first entry" >&2
  failed=1
  return 1
}

failed=0
building_foreach_porcelain_path "$repo_root" _check_path
if [ "$failed" -ne 0 ]; then
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    echo "$line" >&2
  done <<< "$porcelain"
  exit 1
fi

echo "building-001: story-scoped working tree (retry)" >&2
exit 0
