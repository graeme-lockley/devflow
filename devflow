#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

export DEVFLOW_HEAVY_MODEL="github-copilot/claude-opus-4.7"
export DEVFLOW_MEDIUM_MODEL="github-copilot/claude-sonnet-4.5"
export DEVFLOW_LIGHT_MODEL="github-copilot/claude-haiku-4.5"

exec deno run --allow-read --allow-write --allow-run --allow-env "${ROOT}/main.ts" "$@"
