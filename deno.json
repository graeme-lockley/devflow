{
  "name": "@kestrel/devflow",
  "version": "0.1.0",
  "exports": "./main.ts",
  "license": "MIT",
  "publish": {
    "include": [
      "main.ts",
      "src/**/*.ts",
      "templates/**/*",
      "README.md"
    ],
    "exclude": [
      "**/*_test.ts",
      ".devflow/**",
      "docs/**"
    ]
  },
  "tasks": {
    "dev": "deno run --watch --allow-read --allow-write --allow-run --allow-env main.ts",
    "devflow": "deno run --allow-read --allow-write --allow-run --allow-env main.ts",
    "lint": "deno lint --ignore=.devflow",
    "fmt:check": "deno fmt --check --ignore=.devflow",
    "test": "deno test --allow-read --allow-write --allow-run --allow-env",
    "ci": "deno task lint && deno task fmt:check && deno task test"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  }
}
