#!/usr/bin/env bash
set -euo pipefail
# Exit preparing: run prepare-story skill via pi.

board="${1:?board name required}"
card_id="${2:?card id required}"

if [ "${DEVFLOW_SKIP_PI:-}" = "1" ]; then
  echo "DEVFLOW_SKIP_PI=1: skipping pi prepare-story" >&2
  exit 0
fi

if ! command -v pi >/dev/null 2>&1; then
  echo "preparing-002: pi not on PATH" >&2
  exit 1
fi

board_dir="${DEVFLOW_BOARD_DIR:?DEVFLOW_BOARD_DIR not set}"
skill_dir="${board_dir}/skills/prepare-story"
renderer="${board_dir}/scripts/lib/pi-render.sh"
# shellcheck source=lib/pi-prompt.sh
source "${board_dir}/scripts/lib/pi-prompt.sh"
prompt="$(pi_prompt_phase prepare-story prepare)"

set -o pipefail
pi --skill "$skill_dir" --model "${DEVFLOW_HEAVY_MODEL}" --print --mode json \
  "$prompt" \
  | "$renderer"
exit ${PIPESTATUS[0]}
