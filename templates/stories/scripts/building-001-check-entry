#!/usr/bin/env bash
set -euo pipefail
# Exit building (entry): clean tree, or only story-scoped WIP (retry after failed advance).

board="${1:?board name required}"
card_id="${2:?card id required}"
: "$board" "$card_id"

repo_root="${DEVFLOW_REPO_ROOT:?DEVFLOW_REPO_ROOT not set}"
card_dir="${DEVFLOW_CARD_DIR:?DEVFLOW_CARD_DIR not set}"
card_md="${card_dir}/card.md"
repo_root="${repo_root%/}"
card_dir="${card_dir%/}"
card_rel="${card_dir#"$repo_root"/}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=building-lib.sh
source "${script_dir}/building-lib.sh"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "building-001-check-entry: not inside a git work tree" >&2
  exit 1
fi

# Reset BUILD_ROUND at hop start (clean tree entry)
porcelain=$(git -C "$repo_root" status --porcelain)
if [ -z "$porcelain" ]; then
  devflow variable set --board "$board" --card "$card_id" BUILD_ROUND 1 2>/dev/null || true
  exit 0
fi

building_collect_allowed_doc_paths "$card_md"
board_rel="${DEVFLOW_BOARD_DIR:?DEVFLOW_BOARD_DIR not set}"
board_rel="${board_rel#"$repo_root"/}"
building_apply_board_infra_scope "$card_md" "$board_rel"

_check_path() {
  local path="$1"
  if building_path_allowed_for_story "$path" "$card_rel"; then
    return 0
  fi
  case "$path" in
    .devflow/boards/*/scripts/*|.devflow/boards/*/skills/*)
      if [ "${BUILDING_ALLOW_BOARD_INFRA:-0}" = 1 ]; then
        echo "building-001-check-entry: change outside story scope: ${path}" >&2
      else
        echo "building-001-check-entry: board script/skill changes must be committed before advance: ${path}" >&2
      fi
      ;;
    *)
      echo "building-001-check-entry: change outside story scope: ${path}" >&2
      ;;
  esac
  echo "building-001-check-entry: commit or stash unrelated files; a clean tree is required at first entry" >&2
  failed=1
  return 1
}

failed=0
building_foreach_porcelain_path "$repo_root" _check_path
if [ "$failed" -ne 0 ]; then
  while IFS= read -r line; do
    [ -z "$line" ] && continue
    echo "$line" >&2
  done <<< "$porcelain"
  exit 1
fi

echo "building-001-check-entry: story-scoped working tree (retry)" >&2
exit 0
