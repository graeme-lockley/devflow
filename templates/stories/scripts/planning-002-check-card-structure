#!/usr/bin/env bash
set -euo pipefail
# Exit planning: card.md must be ready for plan-story (preparing sections complete).

board="${1:?board name required}"
card_id="${2:?card id required}"
: "$board" "$card_id"

card_dir="${DEVFLOW_CARD_DIR:?DEVFLOW_CARD_DIR not set}"
card_md="${card_dir}/card.md"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=building-lib.sh
source "${script_dir}/building-lib.sh"

stories_card_preparing_ready "$card_md" "planning-002" || exit 1
exit 0
